# ─────────────────────────────────────────────────────────────────────────────
# Freia — environment variables example
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App Environment ───────────────────────────────────────────────────────────
#
# NEXT_PUBLIC_APP_ENV
#   Current environment label: development | staging | production
#
NEXT_PUBLIC_APP_ENV=development

#
# NEXT_PUBLIC_API_URL
#   Base URL for the Freia backend API.
#   Development: http://localhost:3001/api
#   Production:  https://api.freia.ai/api (or your deploy URL)
#
NEXT_PUBLIC_API_URL=http://localhost:3001/api

#
# NEXT_PUBLIC_STORAGE_MODE
#   Controls where providers store/read data:
#     "local" — localStorage (default, zero-setup development)
#     "api"   — backend API (requires running backend + database)
#
NEXT_PUBLIC_STORAGE_MODE=local

# ── WhatsApp Business Platform (Meta Cloud API) ───────────────────────────────
#
# WHATSAPP_VERIFY_TOKEN
#   The token you enter in Meta Business Manager when configuring the webhook.
#   Must match exactly the "Verify Token" value set in your connection form.
#   Generate a strong random string: openssl rand -hex 32
#
WHATSAPP_VERIFY_TOKEN=your-secure-verify-token-here

#
# WHATSAPP_APP_SECRET
#   Found in Meta App Dashboard → App Settings → Basic → App Secret.
#   Used to validate the HMAC-SHA256 signature on every incoming POST request.
#   If not set, signature validation is SKIPPED (not recommended for production).
#
WHATSAPP_APP_SECRET=your-meta-app-secret-here

#
# WHATSAPP_PHONE_NUMBER_ID
#   Found in Meta App Dashboard → WhatsApp → API Setup → Phone number ID.
#   Used as the sender identity for all outbound messages.
#
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here

#
# WHATSAPP_ACCESS_TOKEN
#   System user access token with whatsapp_business_messaging permission.
#   Found in Meta App Dashboard → WhatsApp → API Setup → Temporary access token
#   (use a permanent system user token for production).
#
WHATSAPP_ACCESS_TOKEN=your-system-user-access-token-here

# ── WhatsApp webhook endpoint ─────────────────────────────────────────────────
#
# Register this URL in Meta Business Manager → WhatsApp → Configuration:
#
#   Callback URL : https://YOUR_DOMAIN/api/webhooks/whatsapp
#   Verify Token : same value as WHATSAPP_VERIFY_TOKEN above
#
# Subscribed fields: messages
#
# For local development use a tunnel (ngrok, cloudflared, localtunnel):
#   ngrok http 3000
#   → https://xxxx.ngrok.io/api/webhooks/whatsapp
#
